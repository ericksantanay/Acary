{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",

    "rootDir": "src",
    "outDir": "build",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"]
  },

  "include": ["src", "src/generated", "src/generated/prisma"]
}