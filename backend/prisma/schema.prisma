generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model usuario {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  nome              String 
  email             String  @unique           
  senha             String
  role              String
  perfil            String

  postagens         postagemFamilia[]
  candidaturas      candidatura[]
}

model postagemFamilia {
  id                      String  @id @default(auto()) @map("_id") @db.ObjectId
  cidade                  String
  criancas                Int
  valor                   Int
  responsavel             String 
  dataEhorarioInicio      String
  dataEhorarioTermino     String

  // Família que criou a postagem
  userId                  String   @db.ObjectId
  usuario                 usuario  @relation(fields: [userId], references: [id])

  // Babás que se candidataram
  candidaturas            candidatura[]
}

model candidatura {
  id                      String  @id @default(auto()) @map("_id") @db.ObjectId

  // Babá que fez a candidatura
  usuarioId               String  @db.ObjectId
  usuario                 usuario @relation(fields: [usuarioId], references: [id])

  // Postagem em que ela se candidatou
  postagemId              String  @db.ObjectId
  postagem                postagemFamilia @relation(fields: [postagemId], references: [id])
}
