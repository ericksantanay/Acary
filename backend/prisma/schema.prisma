generator client {
  provider = "prisma-client-ts"
  output   = "../src/generated"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model usuario {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  nome              String 
  email             String  @unique           
  senha             String
  role              String
  perfil            String
}

model postagemFamilia {
  id                      String  @id @default(auto()) @map("_id") @db.ObjectId
  cidade                  String
  criancas                Int
  valor                   Int
  responsavel             String 
  dataEhorarioInicio      String
  dataEhorarioTermino     String
}